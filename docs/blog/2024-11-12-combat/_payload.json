[{"data":1,"prerenderedAt":504},["ShallowReactive",2],{"/blog/2024-11-12-combat":3,"/blog/2024-11-12-combat-surround":497},{"id":4,"title":5,"author":6,"body":10,"date":486,"description":487,"extension":488,"image":489,"meta":490,"minRead":491,"navigation":492,"path":493,"seo":494,"stem":495,"__hash__":496},"blog/blog/2024-11-12-combat.md","Melee Combat System",{"name":7,"avatar":8},"Weizheng Liang",{"src":9,"alt":7},"/img/profile.png",{"type":11,"value":12,"toc":461},"minimark",[13,72,76,94,99,104,115,119,130,134,144,148,159,163,167,170,178,183,186,190,193,197,200,204,207,211,214,221,228,234,241,245,249,256,259,264,267,279,283,286,290,294,298,309,313,324,328,339,343,354,358,362,366,377,381,392,396,407,411,415,426,430,441,451],[14,15,21,22,21,45,21,54,21,63],"div",{"className":16},[17,18,19,20],"grid","grid-cols-2","gap-4","mb-8","\n  ",[14,23,28,29,33,36,37,21],{"className":24},[25,26,27],"bg-blue-50","rounded-lg","p-4","\n    ",[30,31,32],"strong",{},"Link",[34,35],"br",{},"\n     ",[38,39,44],"a",{"href":40,"target":41,"className":42},"https://github.com/WeizhengLiang/melee-combat-system/releases/tag/v0.1","_blank",[43],"text-blue-600","\n      Melee Combat System's Download Page\n    ",[14,46,28,48,51,53],{"className":47},[25,26,27],[30,49,50],{},"Tool",[34,52],{},"\n    C+     Unity \n  ",[14,55,28,57,60,62],{"className":56},[25,26,27],[30,58,59],{},"Role",[34,61],{},"\n    Solo Developer\n  ",[14,64,28,66,69,71],{"className":65},[25,26,27],[30,67,68],{},"Genre",[34,70],{},"\n    Action\n  ",[73,74,75],"p",{},"My journey into combat system development began with an inspiring moment - watching the reveal of \"Black Myth: WuKong\". As a long-time fan of the WuKong character in Chinese traditional culture, seeing this beloved character brought to life in a AAA game sparked my curiosity about combat system development. This curiosity evolved into a dedicated learning project, laying the groundwork for potentially larger game development endeavors.",[77,78,21,81,21,88],"figure",{"className":79},[80],"blog-img-container",[82,83],"img",{"src":84,"className":85,"alt":82,"loading":87},"/img/projects/combat/wukong.png",[86],"blog-img","lazy",[89,90,93],"figcaption",{"className":91},[92],"blog-img-caption","Wukong",[95,96,98],"h2",{"id":97},"key-features","Key Features",[100,101,103],"h3",{"id":102},"dynamic-combo-system","Dynamic Combo System",[77,105,21,107,21,111],{"className":106},[80],[82,108],{"src":109,"className":110,"alt":82,"loading":87},"/img/projects/combat/MCS_003.gif",[86],[89,112,114],{"className":113},[92],"A fast-paced, time-sensitive three-hit combo system that seamlessly transitions from light to heavy attacks, rewarding precise timing and skillful execution.",[100,116,118],{"id":117},"strategic-attack-state-design","Strategic Attack State Design",[77,120,21,122,21,126],{"className":121},[80],[82,123],{"src":124,"className":125,"alt":82,"loading":87},"/img/projects/combat/attack_state.png",[86],[89,127,129],{"className":128},[92],"A meticulously crafted three-phase attack system—Anticipation, Impact, and Recovery—that delivers a rhythmic and engaging combat flow, balancing strategy and intensity.",[100,131,133],{"id":132},"precise-hit-detection-system","Precise Hit Detection System",[77,135,21,137,21,140],{"className":136},[80],[82,138],{"src":109,"className":139,"alt":82,"loading":87},[86],[89,141,143],{"className":142},[92],"An animation-driven hit detection framework that accurately maps weapon trajectories and calculates hit trails for unparalleled combat precision.",[100,145,147],{"id":146},"robust-editor-tools","Robust Editor Tools",[77,149,21,151,21,155],{"className":150},[80],[82,152],{"src":153,"className":154,"alt":82,"loading":87},"/img/projects/combat/editor_window.png",[86],[89,156,158],{"className":157},[92],"Custom-built Unity editor tools that empower developers with an intuitive and efficient setup process for characters, weapons, and attack configurations.",[95,160,162],{"id":161},"technical-implementation","Technical Implementation",[100,164,166],{"id":165},"system-architecture","System Architecture",[73,168,169],{},"The combat system is built on four primary interconnected systems, each handling specific aspects of the gameplay experience:",[77,171,21,173],{"className":172},[80],[82,174],{"src":175,"className":176,"alt":82,"loading":87},"/img/projects/combat/flow.png",[177],"blog-img-large",[179,180,182],"h4",{"id":181},"input-system","Input System",[73,184,185],{},"Centralizes all input processing through the InputManager, which routes combat-specific inputs to the MeleeCombatInput component for specialized handling of attacks, combos, weapon toggles, and defensive actions.",[179,187,189],{"id":188},"combat-system","Combat System",[73,191,192],{},"The core gameplay logic resides in the MeleeCombatSystem, working in conjunction with the WeaponManager for equipment states and the DamageHandler for combat calculations.",[179,194,196],{"id":195},"animation-system","Animation System",[73,198,199],{},"Managed by the RPGCharacterController, this system handles all character animations and their associated events, ensuring smooth transitions between combat states and accurate hit detection.",[179,201,203],{"id":202},"ui-system","UI System",[73,205,206],{},"The CombatUIManager provides real-time feedback through combat state displays, debugging tools, and NPC interaction interfaces.",[100,208,210],{"id":209},"sequence-diagrams","Sequence Diagrams",[73,212,213],{},"The following sequence diagrams illustrate the key interactions between system components during combat actions:",[215,216,217],"ol",{},[218,219,220],"li",{},"Attack Sequence\nDemonstrates the flow of an attack action from input to damage calculation and UI updates:",[77,222,21,224],{"className":223},[80],[82,225],{"src":226,"className":227,"alt":82,"loading":87},"/img/projects/combat/1.png",[177],[215,229,231],{"start":230},2,[218,232,233],{},"Weapon Switch Sequence\nShows the process of switching weapons and updating related systems:",[77,235,21,237],{"className":236},[80],[82,238],{"src":239,"className":240,"alt":82,"loading":87},"/img/projects/combat/2.png",[177],[95,242,244],{"id":243},"technical-challenges","Technical Challenges",[100,246,248],{"id":247},"animation-driven-hit-detection","Animation-Driven Hit Detection",[14,250,255],{"className":251},[252,253,254],"text-red-500","font-semibold","text-lg","Problem",[73,257,258],{},"Synchronizing hit detection with animation frames while maintaining performance.",[14,260,263],{"className":261},[262,253,254],"text-green-500","Solution",[73,265,266],{},"Developed an event-based hit detection system that:",[268,269,270,273,276],"ul",{},[218,271,272],{},"Uses animation events for precise timing",[218,274,275],{},"Implements efficient collision detection",[218,277,278],{},"Manages weapon trail effects",[14,280,282],{"className":281},[43,253,254],"Result",[73,284,285],{},"Significantly reduced setup time for new characters and attacks",[95,287,289],{"id":288},"learning-outcomes","Learning Outcomes",[100,291,293],{"id":292},"technical-skills-gained","Technical Skills Gained",[179,295,297],{"id":296},"combat-system-architecture","Combat System Architecture",[268,299,300,303,306],{},[218,301,302],{},"Modular system design",[218,304,305],{},"Event-driven architecture",[218,307,308],{},"State management patterns",[179,310,312],{"id":311},"unity-development","Unity Development",[268,314,315,318,321],{},[218,316,317],{},"Animation system (Mecanim)",[218,319,320],{},"Custom editor tool development",[218,322,323],{},"Event system implementation",[179,325,327],{"id":326},"game-design","Game Design",[268,329,330,333,336],{},[218,331,332],{},"Combat timing design",[218,334,335],{},"Player feedback systems",[218,337,338],{},"Game feel optimization",[100,340,342],{"id":341},"project-experience","Project Experience",[268,344,345,348,351],{},[218,346,347],{},"Structured system development",[218,349,350],{},"Technical documentation writing",[218,352,353],{},"Combat mechanics implementation",[95,355,357],{"id":356},"future-development","Future Development",[100,359,361],{"id":360},"planned-features","Planned Features",[179,363,365],{"id":364},"combat-system-enhancement","Combat System Enhancement",[268,367,368,371,374],{},[218,369,370],{},"Additional weapon types beyond unarmed and two-hand sword",[218,372,373],{},"More complex combo variations",[218,375,376],{},"Advanced blocking mechanics",[179,378,380],{"id":379},"ai-combat-behaviors","AI Combat Behaviors",[268,382,383,386,389],{},[218,384,385],{},"NPC combat AI",[218,387,388],{},"Enemy behavior patterns",[218,390,391],{},"Dynamic difficulty adjustment",[179,393,395],{"id":394},"system-extensions","System Extensions",[268,397,398,401,404],{},[218,399,400],{},"More character customization options",[218,402,403],{},"Additional animation sets",[218,405,406],{},"Enhanced visual effects",[100,408,410],{"id":409},"technical-improvements","Technical Improvements",[179,412,414],{"id":413},"performance-optimization","Performance Optimization",[268,416,417,420,423],{},[218,418,419],{},"Hit detection optimization",[218,421,422],{},"Animation system refinement",[218,424,425],{},"Memory management improvements",[179,427,429],{"id":428},"code-architecture","Code Architecture",[268,431,432,435,438],{},[218,433,434],{},"Enhanced modularity",[218,436,437],{},"Better event system",[218,439,440],{},"More flexible weapon system",[73,442,443,446,447],{},[30,444,445],{},"Download page",": ",[38,448,5],{"href":40,"rel":449},[450],"nofollow",[73,452,453,446,456],{},[30,454,455],{},"Source code",[38,457,460],{"href":458,"rel":459},"https://github.com/WeizhengLiang/melee-combat-system/tree/main",[450],"Source Code of Melee Combat System",{"title":462,"searchDepth":230,"depth":230,"links":463},"",[464,471,475,478,482],{"id":97,"depth":230,"text":98,"children":465},[466,468,469,470],{"id":102,"depth":467,"text":103},3,{"id":117,"depth":467,"text":118},{"id":132,"depth":467,"text":133},{"id":146,"depth":467,"text":147},{"id":161,"depth":230,"text":162,"children":472},[473,474],{"id":165,"depth":467,"text":166},{"id":209,"depth":467,"text":210},{"id":243,"depth":230,"text":244,"children":476},[477],{"id":247,"depth":467,"text":248},{"id":288,"depth":230,"text":289,"children":479},[480,481],{"id":292,"depth":467,"text":293},{"id":341,"depth":467,"text":342},{"id":356,"depth":230,"text":357,"children":483},[484,485],{"id":360,"depth":467,"text":361},{"id":409,"depth":467,"text":410},"2024-11-12T00:00:00.000Z","A Unity-based combat framework that demonstrates core mechanics of modern action games, featuring combo systems, weapon switching, and animation-driven gameplay.","md","/img/combat.gif",{},10,true,"/blog/2024-11-12-combat",{"title":5,"description":487},"blog/2024-11-12-combat","vb-4W2MDUyG9Aemj18LR_UYCHU5AhnXCLIEkmujFARU",[498,499],null,{"title":500,"path":501,"stem":502,"description":503,"children":-1},"Knock Knock Alien Is Here","/blog/2024-12-30-alien","blog/2024-12-30-alien","Step into the shoes of an unlucky scientist who finds himself on the run from an alien death warrant! In this fast-paced 2D game, you have just 20 seconds to barricade your door and save your life.",1756567458350]